<%- include('partials/header', { title: 'My Account' }) %>

<main class="pt-28 px-margin-mobile md:px-margin-desktop pb-12">
<div class="max-w-container-max mx-auto">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    <!-- Left Column: Profile Card -->
    <div class="lg:col-span-4 space-y-6">
      <div class="glass-card rounded-xl p-8 relative overflow-hidden">
        <div class="aura-glow absolute inset-0 -z-10"></div>
        <div class="flex flex-col items-center text-center">
          <div class="relative w-32 h-32 rounded-full p-1 border-2 border-gold-accent mb-6">
            <div class="w-full h-full rounded-full bg-surface-container-high flex items-center justify-center">
              <span class="material-symbols-outlined text-5xl text-primary">person</span>
            </div>
          </div>
          <h3 id="account-name" class="font-headline-md text-on-surface mb-1">Guest</h3>
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-secondary-container/20 text-gold-accent text-xs font-bold tracking-widest uppercase border border-gold-accent/30">
            <span class="material-symbols-outlined text-sm mr-1" style="font-variation-settings: 'FILL' 1;">star</span> Member
          </span>
        </div>
        <div class="mt-10 space-y-2">
          <a class="flex items-center gap-3 px-4 py-3 rounded-lg bg-white/5 text-primary" href="#">
            <span class="material-symbols-outlined">grid_view</span> <span class="font-label-md">Overview</span>
          </a>
          <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-on-surface-variant hover:bg-white/5 transition-all" href="#">
            <span class="material-symbols-outlined">receipt_long</span> <span class="font-label-md">My Orders</span>
          </a>
          <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-on-surface-variant hover:bg-white/5 transition-all" href="#">
            <span class="material-symbols-outlined">bookmark</span> <span class="font-label-md">Saved Archives</span>
          </a>
          <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-on-surface-variant hover:bg-white/5 transition-all" href="#">
            <span class="material-symbols-outlined">settings</span> <span class="font-label-md">Settings</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Right Column: Dashboard Content -->
    <div class="lg:col-span-8 space-y-8">
      <!-- Welcome Banner -->
      <div class="glass-card rounded-xl p-10 flex flex-col md:flex-row justify-between items-center gap-6 relative">
        <div class="aura-glow absolute inset-0 -z-10 opacity-50"></div>
        <div>
          <h1 id="welcome-name" class="font-display-lg text-display-lg text-on-surface mb-2">Welcome back</h1>
          <p class="text-on-surface-variant font-body-lg">Curating the extraordinary since 2018.</p>
        </div>
        <a href="/catalog" class="bg-primary-container text-on-primary-container px-8 py-4 rounded-lg font-bold tracking-wide hover:shadow-[0_0_20px_rgba(232,177,248,0.4)] transition-all active:scale-95">
          BROWSE NEW ARRIVALS
        </a>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-card rounded-xl p-6 text-center">
          <p class="text-on-surface-variant font-label-md text-xs tracking-widest uppercase mb-2">Total Acquisitions</p>
          <p id="stat-orders" class="font-display-lg text-4xl text-gold-accent">0</p>
        </div>
        <div class="glass-card rounded-xl p-6 text-center">
          <p class="text-on-surface-variant font-label-md text-xs tracking-widest uppercase mb-2">Active Orders</p>
          <p id="stat-active" class="font-display-lg text-4xl text-gold-accent">0</p>
        </div>
        <div class="glass-card rounded-xl p-6 text-center">
          <p class="text-on-surface-variant font-label-md text-xs tracking-widest uppercase mb-2">Member Since</p>
          <p class="font-display-lg text-4xl text-gold-accent">2024</p>
        </div>
      </div>

      <!-- Orders History Table -->
      <div class="glass-card rounded-xl overflow-hidden">
        <div class="px-8 py-6 border-b border-white/10 flex justify-between items-center">
          <h2 class="font-headline-md text-on-surface">My Orders History</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-white/5">
                <th class="px-8 py-4 font-label-md text-on-surface-variant">Order #</th>
                <th class="px-8 py-4 font-label-md text-on-surface-variant">Date</th>
                <th class="px-8 py-4 font-label-md text-on-surface-variant">Total</th>
                <th class="px-8 py-4 font-label-md text-on-surface-variant">Status</th>
              </tr>
            </thead>
            <tbody id="orders-table" class="divide-y divide-white/5">
              <tr><td colspan="4" class="px-8 py-6 text-on-surface-variant text-center">Loading orders...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
</main>

<script>
  async function loadAccount() {
    const token = localStorage.getItem('token');
    if (!token) {
      document.getElementById('account-name').textContent = 'Guest';
      document.getElementById('welcome-name').textContent = 'Welcome back, Guest';
      return;
    }
    try {
      const payload = JSON.parse(atob(token.split('.')[1]));
      document.getElementById('account-name').textContent = payload.email || 'Member';
      document.getElementById('welcome-name').textContent = 'Welcome back, ' + (payload.email || 'Member');
    } catch (e) {}

    // Try to load orders
    try {
      const res = await fetch('/api/admin/orders', { headers: { 'Authorization': 'Bearer ' + token } });
      if (res.ok) {
        const orders = await res.json();
        document.getElementById('stat-orders').textContent = orders.length;
        document.getElementById('stat-active').textContent = orders.filter(o => o.fulfillmentStatus !== 'Delivered' && o.fulfillmentStatus !== 'Cancelled').length;
        if (orders.length) {
          document.getElementById('orders-table').innerHTML = orders.slice(0, 10).map(o => `
            <tr class="hover:bg-white/5 transition-colors">
              <td class="px-8 py-6 font-mono text-sm">#${o.id}</td>
              <td class="px-8 py-6 text-on-surface-variant">${new Date(o.createdAt).toLocaleDateString()}</td>
              <td class="px-8 py-6 text-gold-accent font-bold">$${o.totalAmount.toFixed(2)}</td>
              <td class="px-8 py-6">
                <span class="inline-flex items-center px-3 py-1 rounded-full ${o.fulfillmentStatus === 'Delivered' ? 'bg-green-500/10 text-green-400 border border-green-500/20' : o.fulfillmentStatus === 'Cancelled' ? 'bg-red-500/10 text-red-400 border border-red-500/20' : 'bg-blue-500/10 text-blue-400 border border-blue-500/20'} text-xs font-bold">${o.fulfillmentStatus}</span>
              </td>
            </tr>
          `).join('');
        }
      }
    } catch (e) {}
  }
  loadAccount();
</script>

<%- include('partials/footer') %>
