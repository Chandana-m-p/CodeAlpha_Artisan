<%- include('partials/header', { title: 'Product' }) %>

<main class="pt-28 px-margin-mobile md:px-margin-desktop pb-16">
<div class="max-w-container-max mx-auto">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
    <!-- Left Column: Gallery -->
    <div class="lg:col-span-7 flex flex-col gap-stack-sm">
      <div class="relative aspect-[4/5] rounded-2xl overflow-hidden glass-card group border border-white/10 shadow-2xl">
        <img id="product-image" alt="Luxury jewelry artifact" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" src=""/>
        <div class="absolute inset-0 aura-glow pointer-events-none opacity-40"></div>
        <button onclick="showToast('Added to your saved archives!', 'success')" class="absolute top-6 right-6 p-3 rounded-full bg-surface/50 backdrop-blur-md text-primary border border-white/10 hover:bg-primary hover:text-on-primary transition-all">
          <span class="material-symbols-outlined">favorite</span>
        </button>
      </div>
    </div>

    <!-- Right Column: Product Details -->
    <div class="lg:col-span-5 flex flex-col gap-6">
      <section>
        <nav class="flex items-center gap-2 text-xs font-label-md uppercase tracking-widest text-on-surface-variant/60 mb-4">
          <a href="/catalog" class="hover:text-primary transition-colors">Catalog</a>
          <span class="material-symbols-outlined text-xs">chevron_right</span>
          <span id="product-category" class="text-gold-accent font-bold"></span>
        </nav>
        <h1 id="product-title" class="font-display-lg text-display-lg md:text-4xl text-on-surface tracking-tight mb-3"></h1>
        <div class="flex items-center gap-4 mb-6">
          <span id="product-price" class="font-headline-md text-3xl font-bold text-primary"></span>
          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-gold-accent/10 text-gold-accent font-label-md text-[11px] border border-gold-accent/30 font-bold uppercase tracking-wider">
            <span class="material-symbols-outlined text-xs">verified</span> Certified Masterpiece
          </span>
        </div>
        <div class="flex items-center gap-2 mb-6">
          <div class="flex text-gold-accent">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <span class="text-xs font-label-md text-on-surface-variant">4.9 / 5 (Certified Atelier Reviews)</span>
        </div>
        <p id="product-description" class="font-body-lg text-on-surface-variant text-sm md:text-base mb-8 leading-relaxed"></p>
      </section>

      <!-- Options -->
      <div class="flex flex-col gap-6" id="product-variants"></div>

      <!-- Actions -->
      <div class="flex flex-col gap-4 pt-4">
        <button onclick="addToCart()" class="w-full py-5 bg-primary-container text-on-primary-container font-label-md font-bold text-sm rounded-full primary-glow-button transition-all flex items-center justify-center gap-3 shadow-xl">
          <span class="material-symbols-outlined">auto_awesome</span>
          Add to Collection
        </button>
        <button onclick="showToast('Private Atelier Bespoke inquiry sent!', 'success')" class="w-full py-4 border border-primary/30 bg-white/5 backdrop-blur-md text-primary font-label-md text-xs rounded-full hover:bg-white/10 transition-all flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-sm">draw</span>
          Inquire Bespoke Variation
        </button>
      </div>

      <!-- Accordions -->
      <div class="mt-6 border-t border-white/10">
        <details class="group border-b border-white/10">
          <summary class="flex justify-between items-center py-5 cursor-pointer list-none">
            <span class="font-label-md text-on-surface uppercase tracking-widest text-xs font-bold">Atelier Materials &amp; Purity</span>
            <span class="material-symbols-outlined group-open:rotate-180 transition-transform">keyboard_arrow_down</span>
          </summary>
          <div class="pb-5 text-on-surface-variant text-sm leading-relaxed space-y-2">
            <p>Individually forged, cast, and set under the supervision of lead artisan <strong>Chandana M P</strong>.</p>
            <p>Metals tested for hypoallergenic safety; gemstones sourced ethically with natural clarity certificates.</p>
          </div>
        </details>
        <details class="group border-b border-white/10">
          <summary class="flex justify-between items-center py-5 cursor-pointer list-none">
            <span class="font-label-md text-on-surface uppercase tracking-widest text-xs font-bold">Heritage Care Guide</span>
            <span class="material-symbols-outlined group-open:rotate-180 transition-transform">keyboard_arrow_down</span>
          </summary>
          <div class="pb-5 text-on-surface-variant text-sm leading-relaxed">
            <p>Avoid contact with abrasive chemicals, perfumes, or swimming pools. Clean only using the provided microfiber silk polishing cloth.</p>
          </div>
        </details>
        <details class="group border-b border-white/10">
          <summary class="flex justify-between items-center py-5 cursor-pointer list-none">
            <span class="font-label-md text-on-surface uppercase tracking-widest text-xs font-bold">Insured Logistics &amp; Authenticity</span>
            <span class="material-symbols-outlined group-open:rotate-180 transition-transform">keyboard_arrow_down</span>
          </summary>
          <div class="pb-5 text-on-surface-variant text-sm leading-relaxed">
            <p>Shipped in tamper-evident velvet heirloom boxes with full courier insurance. Includes a physical Certificate of Authenticity signed by Chandana M P.</p>
          </div>
        </details>
      </div>
    </div>
  </div>
</div>
</main>

<script>
  const productId = '<%= productId %>';
  let currentProduct = null;

  async function loadProduct() {
    try {
      const res = await fetch(`/api/products/${productId}`);
      if (!res.ok) throw new Error('Product not found');
      currentProduct = await res.json();
      document.getElementById('product-title').textContent = currentProduct.title;
      document.getElementById('product-price').textContent = '$' + currentProduct.price.toFixed(2);
      document.getElementById('product-description').textContent = currentProduct.description;
      document.getElementById('product-category').textContent = currentProduct.category;
      document.getElementById('product-image').src = currentProduct.image;

      if (currentProduct.variants && currentProduct.variants.length > 0) {
        const variantsHtml = currentProduct.variants.map(v => `
          <div>
            <h3 class="font-label-md text-on-surface mb-3 uppercase tracking-widest text-xs font-bold">${v.name}</h3>
            <div class="flex gap-3">
              <span class="px-4 py-2 rounded-full bg-primary-container/20 text-primary border border-primary/30 font-label-md text-xs font-bold">${v.value}</span>
            </div>
          </div>
        `).join('');
        document.getElementById('product-variants').innerHTML = variantsHtml;
      }
    } catch (e) {
      document.getElementById('product-title').textContent = 'Product not found';
    }
  }

  async function addToCart() {
    if (!currentProduct) return;
    const token = localStorage.getItem('token');
    if (!token) { 
      showToast('Please sign in to add items to your collection', 'error');
      setTimeout(() => window.location.href = '/login', 1200);
      return; 
    }
    try {
      const res = await fetch('/api/cart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ productId: currentProduct.id, quantity: 1 })
      });
      if (res.ok) {
        showToast(`Added ${currentProduct.title} to your collection!`, 'success');
      } else {
        showToast('Failed to add artifact to collection', 'error');
      }
    } catch (e) {
      showToast('Connection error. Please try again.', 'error');
    }
  }

  loadProduct();
</script>

<%- include('partials/footer') %>
