<%- include('partials/header', { title: 'Secure Checkout' }) %>

<main class="pt-28 px-margin-mobile md:px-margin-desktop pb-16">
<div class="max-w-container-max mx-auto">
  <!-- Progress Stepper -->
  <div class="mb-10 flex items-center justify-center gap-4 max-w-xl mx-auto">
    <div class="flex items-center gap-2 text-primary font-label-md text-xs font-bold">
      <span class="w-6 h-6 rounded-full bg-primary/20 border border-primary flex items-center justify-center">1</span>
      <span>Collection</span>
    </div>
    <div class="h-px w-12 bg-primary/40"></div>
    <div class="flex items-center gap-2 text-gold-accent font-label-md text-xs font-bold">
      <span class="w-6 h-6 rounded-full bg-gold-accent text-background flex items-center justify-center font-bold">2</span>
      <span>Checkout</span>
    </div>
    <div class="h-px w-12 bg-white/20"></div>
    <div class="flex items-center gap-2 text-on-surface-variant/40 font-label-md text-xs">
      <span class="w-6 h-6 rounded-full border border-white/20 flex items-center justify-center">3</span>
      <span>Confirmation</span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
    <!-- Left Column: Checkout Info -->
    <div class="lg:col-span-7 space-y-stack-lg">
      <!-- Contact Section -->
      <section class="space-y-stack-md">
        <div class="flex items-center justify-between">
          <h2 class="font-headline-md text-headline-md text-primary flex items-center gap-3">
            <span class="text-gold-accent font-serif italic text-lg">01</span> Contact Information
          </h2>
          <span class="text-on-surface-variant text-xs">Authenticated as <strong class="text-primary">Chandana M P</strong></span>
        </div>
        <div class="liquid-glass p-8 rounded-2xl border border-white/10">
          <div class="space-y-4">
            <label class="block text-on-surface-variant font-label-md text-xs mb-1">Email Address</label>
            <input class="w-full input-elegant py-3 text-body-lg text-on-surface" id="checkout-email" value="chandana@artisancrafted.com" placeholder="chandana@artisancrafted.com" type="email"/>
          </div>
        </div>
      </section>

      <!-- Shipping Section -->
      <section class="space-y-stack-md">
        <h2 class="font-headline-md text-headline-md text-primary flex items-center gap-3">
          <span class="text-gold-accent font-serif italic text-lg">02</span> Shipping Destination
        </h2>
        <div class="liquid-glass p-8 rounded-2xl space-y-6 border border-white/10">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
            <div class="space-y-2">
              <label class="block text-on-surface-variant font-label-md text-xs">First Name</label>
              <input class="w-full input-elegant py-2 text-on-surface" id="shipping-firstName" value="Chandana" type="text"/>
            </div>
            <div class="space-y-2">
              <label class="block text-on-surface-variant font-label-md text-xs">Last Name</label>
              <input class="w-full input-elegant py-2 text-on-surface" id="shipping-lastName" value="M P" type="text"/>
            </div>
          </div>
          <div class="space-y-2">
            <label class="block text-on-surface-variant font-label-md text-xs">Address</label>
            <input class="w-full input-elegant py-2 text-on-surface" id="shipping-address" value="45 Royal Atelier Boulevard" placeholder="123 Artisan Lane" type="text"/>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
            <div class="space-y-2">
              <label class="block text-on-surface-variant font-label-md text-xs">City</label>
              <input class="w-full input-elegant py-2 text-on-surface" id="shipping-city" value="Bengaluru" type="text"/>
            </div>
            <div class="space-y-2">
              <label class="block text-on-surface-variant font-label-md text-xs">Postal Code</label>
              <input class="w-full input-elegant py-2 text-on-surface" id="shipping-postalCode" value="560001" type="text"/>
            </div>
            <div class="space-y-2">
              <label class="block text-on-surface-variant font-label-md text-xs">Country</label>
              <select class="w-full input-elegant py-2 text-on-surface bg-surface-container appearance-none" id="shipping-country">
                <option selected>India</option>
                <option>United Kingdom</option>
                <option>United States</option>
                <option>France</option>
              </select>
            </div>
          </div>
        </div>
      </section>

      <!-- Payment Section -->
      <section class="space-y-stack-md">
        <h2 class="font-headline-md text-headline-md text-primary flex items-center gap-3">
          <span class="text-gold-accent font-serif italic text-lg">03</span> Secure Payment (UPI / Cards)
        </h2>
        <div class="liquid-glass p-8 rounded-2xl space-y-6 border border-white/10">
          <div class="space-y-2">
            <label class="block text-on-surface-variant font-label-md text-xs">Card / UPI Reference</label>
            <input class="w-full input-elegant py-3 text-on-surface tracking-widest" value="4532 &bull;&bull;&bull;&bull; &bull;&bull;&bull;&bull; 8892" placeholder="0000 0000 0000 0000" type="text"/>
          </div>
          <div class="grid grid-cols-2 gap-gutter">
            <div class="space-y-2">
              <label class="block text-on-surface-variant font-label-md text-xs">Expiration (MM/YY)</label>
              <input class="w-full input-elegant py-2 text-on-surface" value="12/28" placeholder="12/26" type="text"/>
            </div>
            <div class="space-y-2">
              <label class="block text-on-surface-variant font-label-md text-xs">CVV</label>
              <input class="w-full input-elegant py-2 text-on-surface" value="888" placeholder="***" type="password"/>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Right Column: Order Summary -->
    <div class="lg:col-span-5">
      <div class="sticky top-28 space-y-stack-md">
        <div class="liquid-glass p-8 rounded-2xl border-t-2 border-primary-container/20 shadow-2xl">
          <h3 class="font-headline-md text-headline-md text-primary mb-8 border-b border-white/5 pb-4">Order Summary</h3>
          <div id="checkout-items" class="space-y-6 mb-8">
            <p class="text-on-surface-variant text-sm">Loading acquisitions...</p>
          </div>
          <div class="space-y-4 border-t border-white/5 pt-8 mb-8">
            <div class="flex justify-between text-on-surface-variant text-sm">
              <span>Subtotal</span><span id="checkout-subtotal">₹0</span>
            </div>
            <div class="flex justify-between text-on-surface-variant text-sm">
              <span>Insured Courier Shipping</span><span>₹1,500</span>
            </div>
            <div class="flex justify-between text-on-surface-variant text-sm">
              <span>GST (18%)</span><span id="checkout-tax">₹0</span>
            </div>
            <div class="flex justify-between text-headline-md text-on-surface font-bold pt-4">
              <span>Total Amount</span><span id="checkout-total" class="text-gold-accent font-bold">₹0</span>
            </div>
          </div>
          <button onclick="placeOrder()" class="w-full py-4 rounded-xl btn-authorize text-on-primary font-bold font-headline-md tracking-wide flex items-center justify-center gap-3 active:scale-95 transition-transform">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">verified_user</span>
            Authorize &amp; Place Order (INR)
          </button>
          <p class="text-[11px] text-center text-on-surface-variant/50 mt-6 leading-relaxed flex items-center justify-center gap-1">
            <span class="material-symbols-outlined text-sm text-gold-accent">lock</span> Encrypted 256-Bit SSL Atelier Order
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
</main>

<script>
  async function loadCheckout() {
    const token = localStorage.getItem('token');
    if (!token) return;
    try {
      const res = await fetch('/api/cart', { headers: { 'Authorization': 'Bearer ' + token } });
      const cart = await res.json();
      let subtotal = 0;
      const html = cart.map(item => {
        const p = item.product;
        if (!p || !p.title) return '';
        const itemPrice = Number(p.price || 0);
        const itemQty = Number(item.quantity || 1);
        const total = itemPrice * itemQty;
        subtotal += total;
        return `
          <div class="flex gap-4 group">
            <div class="relative w-20 h-24 overflow-hidden rounded-xl bg-surface-container-high border border-white/10 shrink-0">
              <img class="w-full h-full object-cover opacity-90" src="${p.image || ''}" alt="${p.title}"/>
            </div>
            <div class="flex flex-col justify-between py-1 flex-grow">
              <div>
                <h4 class="font-body-lg font-medium text-on-surface text-sm">${p.title}</h4>
                <p class="text-xs text-on-surface-variant">${item.selectedVariant || ''}</p>
              </div>
              <p class="font-headline-md text-primary font-bold text-base">₹${total.toLocaleString('en-IN')}</p>
            </div>
          </div>`;
      }).join('');
      document.getElementById('checkout-items').innerHTML = html || '<p class="text-on-surface-variant">No items in your collection.</p>';
      const tax = subtotal * 0.18;
      const grandTotal = subtotal + 1500 + tax;
      document.getElementById('checkout-subtotal').textContent = '₹' + subtotal.toLocaleString('en-IN');
      document.getElementById('checkout-tax').textContent = '₹' + Math.round(tax).toLocaleString('en-IN');
      document.getElementById('checkout-total').textContent = '₹' + Math.round(grandTotal).toLocaleString('en-IN');
    } catch (e) {}
  }

  async function placeOrder() {
    const token = localStorage.getItem('token');
    if (!token) {
      showToast('Please sign in to complete your checkout', 'error');
      setTimeout(() => window.location.href = '/login', 1200);
      return;
    }
    const shippingAddress = {
      firstName: document.getElementById('shipping-firstName').value,
      lastName: document.getElementById('shipping-lastName').value,
      address: document.getElementById('shipping-address').value,
      city: document.getElementById('shipping-city').value,
      postalCode: document.getElementById('shipping-postalCode').value,
      country: document.getElementById('shipping-country').value
    };
    if (!shippingAddress.firstName || !shippingAddress.lastName || !shippingAddress.address || !shippingAddress.city || !shippingAddress.postalCode) {
      showToast('Please fill in all shipping destination fields', 'error');
      return;
    }
    try {
      const res = await fetch('/api/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ shippingAddress })
      });
      if (res.ok) {
        showToast('Acquisition authorized successfully!', 'success');
        setTimeout(() => window.location.href = '/success', 1000);
      } else {
        const data = await res.json();
        showToast(data.message || 'Failed to place order', 'error');
      }
    } catch (e) {
      showToast('Error authorizing order', 'error');
    }
  }

  loadCheckout();
</script>

<%- include('partials/footer') %>
