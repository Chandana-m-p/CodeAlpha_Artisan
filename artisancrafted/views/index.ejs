<%- include('partials/header', { title: 'Home' }) %>

<main class="relative min-h-screen pt-20 overflow-hidden">
  <!-- Background Atmospheric Layer -->
  <div class="absolute inset-0 z-0">
    <div class="w-full h-full bg-cover bg-center opacity-60 filter grayscale-[20%]" style="background-image: url('https://images.unsplash.com/photo-1514894787828-0a2a839c1d1a?auto=format&fit=crop&w=1600&q=80')"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-background via-background/40 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent"></div>
  </div>
  <div class="aura-glow absolute w-[800px] h-[800px] top-[-10%] left-[-10%] opacity-40"></div>
  <div class="aura-glow absolute w-[600px] h-[600px] bottom-[-5%] right-[-5%] opacity-20"></div>

  <div class="relative z-10 container mx-auto px-margin-desktop h-[calc(100vh-80px)] flex flex-col justify-center">
    <div class="grid lg:grid-cols-12 gap-gutter items-center">
      <div class="lg:col-span-6 space-y-stack-md">
        <h1 class="font-display-lg text-display-lg text-primary leading-tight max-w-xl">
          Embrace the <br/>
          <span class="italic text-on-surface opacity-90">exquisite solace.</span>
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-md opacity-80">
          Discover the collections of ArtisanCrafted. Where elegance finds its depth through texture and light.
        </p>
        <div class="flex gap-4 pt-4">
          <a href="/catalog" class="px-12 py-6 rounded-full bg-primary/90 hover:bg-primary transition-colors font-headline-md text-headline-md text-on-primary flex items-center gap-2">
            Browse Collections
            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
          </a>
        </div>
      </div>
      <div class="lg:col-span-6 flex flex-col justify-end items-end h-full py-12">
        <div class="glass-card p-8 rounded-2xl max-w-sm mb-12 floating">
          <p class="font-headline-md text-headline-md text-primary mb-4">Velvet Echoes</p>
          <p class="font-body-md text-on-surface-variant italic mb-6">
            "In the quietude of dusk, we find our truest reflection. Our garments are but shadows of that inner stillness."
          </p>
          <div class="flex items-center gap-2">
            <div class="h-px w-8 bg-primary/40"></div>
            <span class="text-[12px] font-label-md text-on-surface-variant uppercase tracking-widest">L. V. Artisan</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
