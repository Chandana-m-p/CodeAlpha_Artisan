<%- include('partials/header', { title: 'Home' }) %>

<main class="relative min-h-screen pt-20 overflow-hidden">
  <!-- Ultra-Clean High-Definition Seamless Looping Video Layer -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <img src="/images/bg_loop.webp" alt="Atmospheric atelier backdrop video" class="w-full h-full object-cover opacity-75 filter brightness-105 contrast-110 saturate-120 pointer-events-none scale-100 transition-all duration-1000"/>
    <div class="absolute inset-0 bg-gradient-to-r from-background/85 via-background/50 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-background/30"></div>
  </div>

  <div class="aura-glow absolute w-[900px] h-[900px] top-[-15%] left-[-15%] opacity-50"></div>
  <div class="aura-glow absolute w-[700px] h-[700px] bottom-[-10%] right-[-10%] opacity-30"></div>

  <!-- Hero Section -->
  <div class="relative z-10 max-w-container-max mx-auto px-4 md:px-margin-desktop min-h-[calc(100vh-80px)] flex flex-col justify-center py-12">
    <div class="grid lg:grid-cols-12 gap-gutter items-center">
      <div class="lg:col-span-7 space-y-stack-md">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full liquid-glass border border-gold-accent/40 text-gold-accent text-xs font-label-md tracking-widest uppercase">
          <span class="material-symbols-outlined text-sm">auto_awesome</span> Handcrafted Atelier Series 2026
        </div>
        <h1 class="font-display-lg text-display-lg md:text-[60px] text-primary leading-tight max-w-2xl">
          Where Mastery Meets <br/>
          <span class="italic text-on-surface opacity-90 champagne-accent">Timeless Solace.</span>
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-lg opacity-90 leading-relaxed">
          Curated by lead artisan <strong class="text-primary">Chandana M P</strong>. Discover rare fine jewelry, sculptural ceramics, and hand-finished leather goods crafted to transcend generations.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <a href="/catalog" class="px-10 py-5 rounded-full bg-primary-container text-on-primary-container font-label-md font-bold text-sm flex items-center gap-3 primary-glow-button hover:scale-105 transition-all">
            Browse Collections
            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
          </a>
          <a href="#heritage" class="px-8 py-5 rounded-full border border-white/20 hover:border-primary text-on-surface font-label-md text-sm backdrop-blur-md hover:bg-white/5 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">menu_book</span> Explore Atelier Heritage
          </a>
        </div>
      </div>

      <div class="lg:col-span-5 flex flex-col justify-center items-end">
        <div class="glass-card p-8 rounded-2xl max-w-md w-full floating border-t-2 border-gold-accent/40 shadow-2xl relative">
          <div class="flex justify-between items-start mb-6">
            <span class="text-xs uppercase tracking-widest text-gold-accent font-label-md font-bold">Featured Artifact</span>
            <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-[10px] uppercase font-bold border border-primary/20">Limited Batch</span>
          </div>
          <div class="w-full h-48 rounded-xl overflow-hidden mb-6 relative group">
            <img src="https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?auto=format&fit=crop&w=800&q=80" alt="Ethereal Mist Amethyst Pendant" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"/>
            <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent opacity-80"></div>
            <span class="absolute bottom-3 left-4 text-sm font-bold text-gold-accent">₹95,000 INR</span>
          </div>
          <h3 class="font-headline-md text-headline-md text-primary mb-2">Ethereal Mist Amethyst Pendant</h3>
          <p class="font-body-md text-on-surface-variant italic mb-6 text-sm">
            "A hand-finished pendant in 925 sterling silver set with a genuine 4.2-carat veiled amethyst gemstone."
          </p>
          <div class="flex items-center justify-between border-t border-white/10 pt-4">
            <span class="text-[12px] font-label-md text-on-surface-variant uppercase tracking-widest">Master Artisan: Chandana M P</span>
            <a href="/catalog" class="text-primary hover:underline text-xs font-bold flex items-center gap-1">Details <span class="material-symbols-outlined text-sm">chevron_right</span></a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Trust & Stats Metric Bar -->
  <section class="relative z-10 border-y border-white/10 bg-surface-container-lowest/80 backdrop-blur-md py-10">
    <div class="max-w-container-max mx-auto px-4 md:px-margin-desktop grid grid-cols-2 md:grid-cols-4 gap-gutter text-center">
      <div class="space-y-1">
        <p class="font-display-lg text-3xl md:text-4xl text-gold-accent font-bold">100%</p>
        <p class="font-label-md text-xs uppercase tracking-widest text-on-surface-variant">Master Handcrafted</p>
      </div>
      <div class="space-y-1">
        <p class="font-display-lg text-3xl md:text-4xl text-gold-accent font-bold">Insured</p>
        <p class="font-label-md text-xs uppercase tracking-widest text-on-surface-variant">Pan-India &amp; Global Shipping</p>
      </div>
      <div class="space-y-1">
        <p class="font-display-lg text-3xl md:text-4xl text-gold-accent font-bold">Verified</p>
        <p class="font-label-md text-xs uppercase tracking-widest text-on-surface-variant">Certificate of Authenticity</p>
      </div>
      <div class="space-y-1">
        <p class="font-display-lg text-3xl md:text-4xl text-gold-accent font-bold">Limited</p>
        <p class="font-label-md text-xs uppercase tracking-widest text-on-surface-variant">Numbered Editions</p>
      </div>
    </div>
  </section>

  <!-- Curated Collection Spotlight Section -->
  <section class="relative z-10 py-24 max-w-container-max mx-auto px-4 md:px-margin-desktop">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-4">
      <div>
        <span class="text-gold-accent text-xs font-label-md uppercase tracking-widest">Curated Atelier</span>
        <h2 class="font-display-lg text-display-lg text-on-surface mt-1">Featured Artifacts</h2>
      </div>
      <a href="/catalog" class="text-primary hover:text-primary-fixed-dim font-label-md text-sm flex items-center gap-2 group">
        Explore Full Catalog <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
      <!-- Item 1 -->
      <div class="glass-card rounded-xl overflow-hidden group relative flex flex-col">
        <div class="h-72 overflow-hidden relative">
          <img src="https://images.unsplash.com/photo-1603561591411-07134e71a2a9?auto=format&fit=crop&w=800&q=80" alt="Sapphire Wave Ring" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"/>
          <span class="absolute top-4 right-4 bg-surface/80 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-gold-accent border border-gold-accent/30">₹48,000</span>
        </div>
        <div class="p-6 flex flex-col flex-grow">
          <span class="text-[11px] font-label-md text-primary/70 uppercase tracking-widest">Fine Jewelry</span>
          <h3 class="font-headline-md text-xl text-on-surface my-2">Sapphire Wave Ring</h3>
          <p class="text-on-surface-variant text-sm line-clamp-2 mb-6">Sculptural 14K gold ring set with a deep midnight blue sapphire.</p>
          <a href="/catalog" class="mt-auto py-3 text-center rounded-lg bg-white/5 border border-white/10 text-primary font-label-md text-xs hover:bg-primary hover:text-on-primary transition-all">View Piece</a>
        </div>
      </div>
      <!-- Item 2 -->
      <div class="glass-card rounded-xl overflow-hidden group relative flex flex-col">
        <div class="h-72 overflow-hidden relative">
          <img src="https://images.unsplash.com/photo-1610701596007-11502861dcfa?auto=format&fit=crop&w=800&q=80" alt="Velvet Glen Ceramic Vessel" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"/>
          <span class="absolute top-4 right-4 bg-surface/80 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-gold-accent border border-gold-accent/30">₹12,500</span>
        </div>
        <div class="p-6 flex flex-col flex-grow">
          <span class="text-[11px] font-label-md text-primary/70 uppercase tracking-widest">Ceramics</span>
          <h3 class="font-headline-md text-xl text-on-surface my-2">Velvet Glen Ceramic Vessel</h3>
          <p class="text-on-surface-variant text-sm line-clamp-2 mb-6">Hand-thrown ceramic jewelry vessel with twilight enamel glaze.</p>
          <a href="/catalog" class="mt-auto py-3 text-center rounded-lg bg-white/5 border border-white/10 text-primary font-label-md text-xs hover:bg-primary hover:text-on-primary transition-all">View Piece</a>
        </div>
      </div>
      <!-- Item 3 -->
      <div class="glass-card rounded-xl overflow-hidden group relative flex flex-col">
        <div class="h-72 overflow-hidden relative">
          <img src="https://images.unsplash.com/photo-1627123424574-724758594e93?auto=format&fit=crop&w=800&q=80" alt="Luna Italian Leather Travel Wallet" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"/>
          <span class="absolute top-4 right-4 bg-surface/80 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-gold-accent border border-gold-accent/30">₹18,500</span>
        </div>
        <div class="p-6 flex flex-col flex-grow">
          <span class="text-[11px] font-label-md text-primary/70 uppercase tracking-widest">Leather Goods</span>
          <h3 class="font-headline-md text-xl text-on-surface my-2">Luna Italian Leather Travel Wallet</h3>
          <p class="text-on-surface-variant text-sm line-clamp-2 mb-6">Full-grain Italian calfskin pouch designed for jewelry and luxury timepieces.</p>
          <a href="/catalog" class="mt-auto py-3 text-center rounded-lg bg-white/5 border border-white/10 text-primary font-label-md text-xs hover:bg-primary hover:text-on-primary transition-all">View Piece</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Atelier Heritage Section -->
  <section id="heritage" class="relative z-10 py-24 bg-surface-container-low/40 border-t border-white/10">
    <div class="max-w-container-max mx-auto px-4 md:px-margin-desktop grid lg:grid-cols-12 gap-gutter items-center">
      <div class="lg:col-span-6">
        <div class="relative rounded-2xl overflow-hidden glass-card p-2">
          <img src="https://images.unsplash.com/photo-1544816155-12df9643f363?auto=format&fit=crop&w=1200&q=80" alt="Craftsmanship Studio" class="w-full h-[450px] object-cover rounded-xl"/>
          <div class="absolute inset-0 bg-gradient-to-t from-background/90 via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8 right-8 p-6 glass-card rounded-xl border border-white/10">
            <p class="text-xs uppercase font-label-md tracking-widest text-gold-accent mb-1">Authentic Craft Guarantee</p>
            <p class="text-sm text-on-surface-variant italic">"Every creation represents hours of careful sculpting, refining, and polishing."</p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-6 space-y-6">
        <span class="text-gold-accent text-xs font-label-md uppercase tracking-widest">Atelier Heritage</span>
        <h2 class="font-display-lg text-display-lg text-on-surface">Crafted by Chandana M P</h2>
        <p class="text-on-surface-variant font-body-lg leading-relaxed">
          Founded on the principle of uncompromised craftsmanship, ArtisanCrafted brings together rare materials and artisanal techniques. Each item is hand-selected, verified, and stamped with a unique atelier serial number.
        </p>
        <div class="space-y-4 pt-2">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0"><span class="material-symbols-outlined">verified</span></div>
            <div>
              <h4 class="font-headline-md text-lg text-on-surface">Personalized Certification</h4>
              <p class="text-on-surface-variant text-sm">Comes with a physical certificate of authenticity signed by Chandana M P.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0"><span class="material-symbols-outlined">shield</span></div>
            <div>
              <h4 class="font-headline-md text-lg text-on-surface">Lifetime Atelier Care</h4>
              <p class="text-on-surface-variant text-sm">Complimentary cleaning, polishing, and stone inspection services.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
